---
title: Executive Coaching for Leaders and Teams
description: Executive and team coaching for visionary leaders and teams committed to building a better world. Resources, newsletters, essays, and guides for support along the way.
keywords: executive coach, leadership coach, executive team coach, leadership team coach, design leadership coaching, executive team coaching, Andrea Mignolo
image: "og/og-symbol.png"
layout: content
---

<section class="hero full-width">
  <div class="text">
    <h1>For <%= link_to('senior leaders', 'who') %> facing complex organizational challenges who want to do meaningful work without losing themselves.</h1>
  </div>
  <hr />
</section>

<section class="full-width">
    <div class="nav-paragraphs premise">
      <h2>Does it sometimes feel like you have to be someone you’re not in order to be an effective leader?</h2>

      <h3>You’ve worked hard to get here. Some days you’re on fire, and other days you feel reactive and exhausted, wondering where your confidence went.</h3>

      <h3>This oscillation between flow and frustration is common on the leadership journey, and frequently shows up when leaders are pushing up against their growth edge, where fear based patterns and limiting beliefs can be the loudest.</h3>

      <h3>The good news is that there is nothing wrong with you. This is, in fact, a wonderful place to be. It is a sign that you are ready to evolve your leadership into something more aligned and true to who you really are.</h3>
    </div>

    <hr />

    <div class="nav-paragraphs">
      <div class="about-company"><h2>METHOD & MATTER is a leadership and work coaching company based in San Francisco, offering executive coaching for <%= link_to('leaders', 'executive-coaching') %> and <%= link_to('teams', 'team-coaching') %>, cohort-based <%= link_to('leadership programs', 'leadership-programs') %>, and in-person experiential <%= link_to('offsites', 'offsites') %>.</h2></div>
    </div>

</section>

<hr />
    <!-- Featured content grid — Added by Claude Code - 2026-06-06 -->
    <div class="featured-content">
      <%
        wmw_articles   = blog("words-make-worlds").articles.select { |a| a.data.published != false }.first(3)
        essay_articles = blog("essays").articles.select { |a| a.data.published != false }.sample(2)

        guide_resources = sitemap.resources.select { |r|
          r.path =~ /^writing\/guides\/.+\.html$/ &&
          r.data.respond_to?(:published) &&
          r.data.published != false
        }.sort_by { |g| g.data.title.to_s }

        featured_guide = guide_resources.find { |g| g.data.respond_to?(:featured) && g.data.featured } ||
                         (guide_resources.any? ? guide_resources[Date.today.yday % guide_resources.length] : nil)

        announcements = begin
          data.announcements ? Array(data.announcements) : []
        rescue
          []
        end

        # Dynamic title sizing: font scales inversely with title length, calibrated per card type.
        # card_size: :essay (2-col tall), :note (2-col short italic), :article (2-col short),
        #            :guide (2-col tall, image), :strip (4-col short), :small (1-col short)
        card_title_size = ->(title, card_size) {
          len = title.to_s.length
          case card_size
          when :essay   # 2-col × 7 rows
            case len
            when  0..8  then "clamp(2.5rem, 5.5vw, 6rem)"
            when  9..16 then "clamp(2rem, 4.5vw, 5rem)"
            when 17..30 then "clamp(1.8rem, 3.5vw, 4rem)"
            else             "clamp(1.4rem, 2.5vw, 3rem)"
            end
          when :note    # 2-col × 3 rows, italic pull quote
            case len
            when  0..8  then "clamp(2.5rem, 4.5vw, 4.5rem)"
            when  9..16 then "clamp(2rem, 3.5vw, 3.5rem)"
            when 17..25 then "clamp(1.8rem, 3vw, 3rem)"
            else             "clamp(1.5rem, 2.5vw, 2.5rem)"
            end
          when :article # 2-col × 3 rows
            case len
            when  0..8  then "clamp(2.5rem, 5vw, 5rem)"
            when  9..20 then "clamp(1.8rem, 3.5vw, 4rem)"
            when 21..35 then "clamp(1.4rem, 2.5vw, 3rem)"
            else             "clamp(1.1rem, 2vw, 2.5rem)"
            end
          when :guide   # 2-col × 7 rows, image background
            case len
            when  0..16 then "clamp(1.5rem, 2.8vw, 3.5rem)"
            when 17..30 then "clamp(1.2rem, 2.2vw, 3rem)"
            else             "clamp(1rem, 1.8vw, 2.5rem)"
            end
          when :strip   # 4-col × 2 rows (essay secondary)
            case len
            when  0..10 then "clamp(2.5rem, 5vw, 5rem)"
            when 11..20 then "clamp(2rem, 4vw, 4.5rem)"
            when 21..35 then "clamp(1.8rem, 3vw, 4rem)"
            else             "clamp(1.4rem, 2.5vw, 3rem)"
            end
          when :small   # 1-col × 3 rows (WMW secondary)
            case len
            when  0..6  then "clamp(2rem, 2.5vw, 3.5rem)"
            when  7..15 then "clamp(1.5rem, 2vw, 2.8rem)"
            when 16..30 then "clamp(1.2rem, 1.5vw, 2.2rem)"
            else             "clamp(1.1rem, 1.3vw, 1.8rem)"
            end
          end
        }
      %>

      <div class="featured-grid">
        <% announcements.each do |item| %>
          <a href="<%= item.url %>" class="card card--announcement">
            <span class="card-label"><%= item.type || "Announcement" %></span>
            <h3 class="card-title"><%= item.title %></h3>
            <% if item.description %><p class="card-description"><%= item.description %></p><% end %>
            <% if item.date %><time class="card-date"><%= item.date %></time><% end %>
          </a>
        <% end %>

        <% if wmw_articles[0] %>
          <% wmw_is_article = wmw_articles[0].data.respond_to?(:issue) && wmw_articles[0].data.issue %>
          <a href="<%= wmw_articles[0].url %>" class="card card--wmw <%= wmw_is_article ? 'card--primary' : 'card--note' %>">
            <span class="card-label"><%= wmw_is_article ? 'Words Make Worlds' : 'Note' %></span>
            <% if wmw_is_article %>
              <span class="card-issue">№&nbsp;<%= wmw_articles[0].data.issue %></span>
              <h3 class="card-title" style="font-size: <%= card_title_size.(wmw_articles[0].title, :article) %>"><%= wmw_articles[0].title %></h3>
            <% else %>
              <h3 class="card-title" style="font-size: <%= card_title_size.(wmw_articles[0].title, :note) %>"><%= wmw_articles[0].title %></h3>
            <% end %>
          </a>
        <% end %>

        <% if essay_articles[0] %>
          <a href="<%= essay_articles[0].url %>" class="card card--essay card--primary">
            <span class="card-label">Essay</span>
            <h3 class="card-title" style="font-size: <%= card_title_size.(essay_articles[0].title, :essay) %>"><%= essay_articles[0].title %></h3>
          </a>
        <% end %>

        <% if featured_guide %>
          <% guide_bg = featured_guide.data.masthead.to_s[/url\([^)]+\)/] if featured_guide.data.masthead %>
          <a href="<%= featured_guide.url %>"
             class="card card--guide<%= guide_bg ? ' card--has-image' : '' %>"
             <%= "style=\"background-image: #{guide_bg};\"".html_safe if guide_bg %>>
            <div class="guide-description">
              <span class="card-label">Guide</span>
              <h3 class="card-title" style="font-size: <%= card_title_size.(featured_guide.data.title, guide_bg ? :guide : :essay) %>"><%= featured_guide.data.title %></h3>
              <% if featured_guide.data.respond_to?(:subtitle) && featured_guide.data.subtitle %>
                <p class="card-description"><%= featured_guide.data.subtitle %></p>
                <% end %>
            </div>
          </a>
        <% end %>

        <% wmw_articles[1..2].compact.each do |article| %>
          <a href="<%= article.url %>" class="card card--wmw card--secondary">
            <span class="card-label">Words Make Worlds</span>
            <% if article.data.issue %>
              <span class="card-issue">№&nbsp;<%= article.data.issue %></span>
            <% end %>
            <h3 class="card-title" style="font-size: <%= card_title_size.(article.title, :small) %>"><%= article.title %></h3>
          </a>
        <% end %>

        <% if essay_articles[1] %>
          <a href="<%= essay_articles[1].url %>" class="card card--essay card--secondary">
            <span class="card-label">Essay</span>
            <h3 class="card-title" style="font-size: <%= card_title_size.(essay_articles[1].title, :strip) %>"><%= essay_articles[1].title %></h3>
          </a>
        <% end %>
      </div>
    </div>

    <hr/>

